# Solana (use devnet for local development)
SOLANA_RPC=https://api.devnet.solana.com

# Casino wallet — generate with backend/scripts/generateWallet.js or README one-liner
CASINO_PRIVATE_KEY=<your-base58-private-key>
CASINO_WALLET_PUBLIC_KEY=<your-wallet-public-key>

# MongoDB (local Docker: mongodb://admin:password@localhost:27017/luciddrop?authSource=admin)
MONGODB_URI=mongodb://localhost:27017/luciddrop

# Auth
JWT_SECRET=<your-jwt-secret-min-32-chars>

# CORS / Socket.io
FRONTEND_URL=http://localhost:3000

# Server
PORT=5000
NODE_ENV=development
