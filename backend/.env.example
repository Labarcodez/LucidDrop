# Solana Configuration
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Casino Wallet Private Key (base58 encoded secret key)
# Generate with: node -e "const {Keypair}=require('@solana/web3.js'); console.log(require('bs58').encode(Keypair.generate().secretKey))"
CASINO_PRIVATE_KEY=<your-base58-private-key>

# Casino Wallet Public Key (derived from private key)
CASINO_WALLET_PUBLIC_KEY=<your-wallet-public-key>

# MongoDB
MONGODB_URI=mongodb://localhost:27017/luciddrop

# JWT
JWT_SECRET=<your-jwt-secret>

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
